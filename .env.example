# Optional storage defaults. These are hidden in the Streamlit UI.
RAG_DATA_DIR=.rag_data/documents
RAG_CHROMA_DIR=.rag_data/chroma
# Optional override. Leave blank/commented to auto-generate from embedding provider and model.
# RAG_COLLECTION=

# Embedding defaults.
RAG_EMBEDDING_PROVIDER=openai-compatible
RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_API_KEY=
RAG_ALLOW_REMOTE_EMBEDDINGS=false

# For fully local embeddings, set:
# RAG_EMBEDDING_PROVIDER=sentence-transformers
# RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chat model defaults. Set RAG_ALLOW_REMOTE_CHAT=true only when you intend
# to send questions and retrieved document chunks to a hosted endpoint.
RAG_LLM_BACKEND=openai-compatible
RAG_OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
RAG_OPENAI_COMPAT_MODEL=gpt-4o-mini
RAG_OPENAI_COMPAT_API_KEY=
RAG_ALLOW_REMOTE_CHAT=false

# Local Ollama fallback.
RAG_OLLAMA_HOST=http://localhost:11434
RAG_OLLAMA_MODEL=llama3:latest

# Optional Microsoft Graph OneDrive connector.
# Create a public client app registration in Microsoft Entra ID and grant:
# User.Read, Files.Read, offline_access.
ONEDRIVE_CLIENT_ID=
ONEDRIVE_TENANT_ID=common
